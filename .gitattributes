# Normalize line endings to LF for all text files
* text=auto

# Force LF for specific file types
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.xml text eol=lf

# Don't normalize binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
